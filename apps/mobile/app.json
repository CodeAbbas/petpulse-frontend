{
  "expo": {
    "name": "PetPulse",
    "slug": "petpulse-mobile",
    "android": {
      "package": "website.petpulse",
      "googleServicesFile": "./google-services.json",
      "useNextNotificationsApi": true,
      "permissions": [
        "NOTIFICATIONS",
        "POST_NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        { "color": "#0ea5e9", "defaultChannel": "default" }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "PetPulse uses your location to find the nearest 24/7 emergency clinics."
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsDownloadToken": ""
        }
      ],
      "./withFirebaseManifestFix.js",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging"
    ],
    "extra": {
      "eas": {
        "projectId": "029bf8ef-f810-488b-83aa-757835320743"
      }
    }
  }
}