{
  "expo": {
    "name": "PetPulse",
    "slug": "petpulse-mobile",
    "android": {
      "package": "website.petpulse",
      "googleServicesFile": "./google-services.json",
      "useNextNotificationsApi": true,
      "permissions": [
        "NOTIFICATIONS",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#0ea5e9",
          "defaultChannel": "default"
        }
      ],
      "./withFirebaseManifestFix.js",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging"
    ],
    "extra": {
      "eas": {
        "projectId": "029bf8ef-f810-488b-83aa-757835320743"
      }
    }
  }
}
